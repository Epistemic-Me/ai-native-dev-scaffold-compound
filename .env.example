# Clarity API Credentials (required for compound loop)
# Get these from https://epistemicme.ai or contact the Epistemic Me team
CLARITY_API_URL=https://clarity-self-learning-agent.onrender.com
CLARITY_API_KEY=your_api_key_here
CLARITY_USER_ID=           # Set after running: python compound.py init
CLARITY_SELF_MODEL_ID=     # Set after running: python compound.py init

# Optional: External config directory (defaults to ./scripts)
# COMPOUND_CONFIG_DIR=./scripts

# Optional: Journey specs directory for stakeholder goals
# COMPOUND_JOURNEY_SPECS_DIR=./config/journey_specs
